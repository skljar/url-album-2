import { Button, HorizontalBox, VerticalBox, LineEdit, ScrollView } from "std-widgets.slint";

export struct FolderNode {
    id: int,
    title: string,
    depth: int,
    expanded: bool,
    has-children: bool,
    selected: bool,
}

export struct BookmarkItem {
    id: int,
    title: string,
    url: string,
    selected: bool,
}

export component MainWindow inherits Window {
    title: "URL Album 3";
    preferred-width: 900px;
    preferred-height: 600px;
    min-width: 500px;
    min-height: 300px;
    background: #ffffff;

    // Data
    in property <[FolderNode]> folders;
    in property <[BookmarkItem]> bookmarks;
    in property <string> status-text: "Готов";

    // Dialog visibility
    in-out property <bool> show-folder-dlg: false;
    in-out property <bool> show-bookmark-dlg: false;
    in-out property <bool> show-search: false;
    in-out property <string> search-query: "";

    // Callbacks
    callback folder-clicked(int);
    callback folder-toggle(int);
    callback bookmark-open(string);
    callback bookmark-clicked(int);
    callback new-folder-confirmed(string);
    callback new-bookmark-confirmed(string, string);
    callback delete-selected();
    callback search-changed(string);
    callback import-uadat();
    callback new-db();
    callback open-db();

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Toolbar
        Rectangle {
            height: 36px;
            background: #f5f5f5;
            border-color: #ddd;
            border-width: 0px;

            HorizontalBox {
                padding: 4px;
                spacing: 4px;
                alignment: start;

                Button { text: "+ Папка"; clicked => { root.show-folder-dlg = true; } }
                Button { text: "+ Ссылка"; clicked => { root.show-bookmark-dlg = true; } }
                Rectangle { width: 8px; }
                Button { text: "Удалить"; clicked => { root.delete-selected(); } }
                Rectangle { width: 8px; }
                Button { text: "Импорт ua.dat"; clicked => { root.import-uadat(); } }
                Rectangle { width: 8px; }
                search-box := LineEdit {
                    width: 180px;
                    placeholder-text: "Поиск... (Ctrl+F)";
                    edited => { root.search-changed(self.text); }
                }
            }
        }

        // Main area: tree + list
        HorizontalBox {
            padding: 0px;
            spacing: 0px;
            vertical-stretch: 1;

            // Left panel: folder tree
            Rectangle {
                width: 220px;
                background: #fafafa;
                border-color: #e0e0e0;
                border-width: 1px;

                ScrollView {
                    VerticalBox {
                        padding: 4px;
                        spacing: 1px;
                        alignment: start;

                        for f in root.folders: Rectangle {
                            height: 24px;
                            background: f.selected ? #0078d4 : transparent;
                            border-radius: 3px;

                            TouchArea {
                                clicked => { root.folder-clicked(f.id); }
                            }

                            HorizontalBox {
                                padding-left: f.depth * 14px + 2px;
                                padding-right: 4px;
                                padding-top: 2px;
                                padding-bottom: 2px;
                                spacing: 3px;

                                // Expand arrow
                                Rectangle {
                                    width: 14px;
                                    background: transparent;
                                    Text {
                                        text: f.has-children ? (f.expanded ? "v" : ">") : " ";
                                        color: f.selected ? #ffffff : #888888;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    TouchArea {
                                        clicked => { root.folder-toggle(f.id); }
                                    }
                                }

                                // Folder name
                                Text {
                                    text: f.title;
                                    color: f.selected ? #ffffff : #222222;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }
                }
            }

            // Right panel: bookmark list
            VerticalBox {
                padding: 0px;
                spacing: 0px;
                horizontal-stretch: 1;

                // Column header
                Rectangle {
                    height: 22px;
                    background: #f0f0f0;
                    border-color: #ddd;
                    border-width: 1px;

                    HorizontalBox {
                        padding-left: 6px;
                        spacing: 0px;
                        Text { text: "Название"; font-size: 11px; color: #555; width: 240px; vertical-alignment: center; }
                        Text { text: "URL"; font-size: 11px; color: #555; vertical-alignment: center; }
                    }
                }

                // Bookmark rows
                ScrollView {
                    vertical-stretch: 1;
                    VerticalBox {
                        padding: 4px;
                        spacing: 1px;
                        alignment: start;

                        for b in root.bookmarks: Rectangle {
                            height: 22px;
                            background: b.selected ? #0078d4 : transparent;
                            border-radius: 2px;

                            TouchArea {
                                clicked => { root.bookmark-clicked(b.id); }
                                double-clicked => { root.bookmark-open(b.url); }
                            }

                            HorizontalBox {
                                padding-left: 6px;
                                padding-right: 4px;
                                padding-top: 2px;
                                padding-bottom: 2px;
                                spacing: 0px;

                                Text {
                                    text: b.title;
                                    color: b.selected ? #ffffff : #222222;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    width: 240px;
                                    overflow: elide;
                                }
                                Text {
                                    text: b.url;
                                    color: b.selected ? #cce5ff : #0066cc;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }
                }
            }
        }

        // Status bar
        Rectangle {
            height: 20px;
            background: #f5f5f5;
            border-color: #ddd;
            border-width: 1px;
            HorizontalBox {
                padding-left: 8px;
                Text { text: root.status-text; font-size: 11px; color: #666; vertical-alignment: center; }
            }
        }
    }

    // === New Folder Dialog ===
    if root.show-folder-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-folder-dlg = false; } }

        Rectangle {
            width: 320px;
            height: 140px;
            background: #ffffff;
            border-radius: 6px;
            border-color: #ccc;
            border-width: 1px;
            drop-shadow-blur: 12px;
            drop-shadow-color: #44000000;

            VerticalBox {
                padding: 16px;
                spacing: 12px;

                Text { text: "Новая папка"; font-size: 14px; font-weight: 700; color: #222; }

                folder-name-input := LineEdit { placeholder-text: "Название папки"; }

                HorizontalBox {
                    spacing: 8px;
                    alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-folder-dlg = false; } }
                    Button {
                        text: "Создать";
                        primary: true;
                        clicked => {
                            if folder-name-input.text != "" {
                                root.new-folder-confirmed(folder-name-input.text);
                                root.show-folder-dlg = false;
                            }
                        }
                    }
                }
            }
        }
    }

    // === New Bookmark Dialog ===
    if root.show-bookmark-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-bookmark-dlg = false; } }

        Rectangle {
            width: 400px;
            height: 190px;
            background: #ffffff;
            border-radius: 6px;
            border-color: #ccc;
            border-width: 1px;
            drop-shadow-blur: 12px;
            drop-shadow-color: #44000000;

            VerticalBox {
                padding: 16px;
                spacing: 10px;

                Text { text: "Новая ссылка"; font-size: 14px; font-weight: 700; color: #222; }

                bm-url := LineEdit { placeholder-text: "URL (https://...)"; }
                bm-title := LineEdit { placeholder-text: "Название (необязательно)"; }

                HorizontalBox {
                    spacing: 8px;
                    alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-bookmark-dlg = false; } }
                    Button {
                        text: "Добавить";
                        primary: true;
                        clicked => {
                            if bm-url.text != "" {
                                root.new-bookmark-confirmed(bm-title.text, bm-url.text);
                                root.show-bookmark-dlg = false;
                            }
                        }
                    }
                }
            }
        }
    }
}
