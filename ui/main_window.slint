import { Button, HorizontalBox, VerticalBox, LineEdit, ScrollView, TextEdit } from "std-widgets.slint";

export struct FolderNode {
    id: int,
    title: string,
    depth: int,
    expanded: bool,
    has-children: bool,
    selected: bool,
}

export struct BookmarkItem {
    id: int,
    title: string,
    url: string,
    note: string,
    selected: bool,
}

export component MainWindow inherits Window {
    title: "URL Album 3";
    preferred-width: 960px;
    preferred-height: 640px;
    min-width: 500px;
    min-height: 350px;
    background: #ffffff;

    // Data
    in property <[FolderNode]> folders;
    in property <[BookmarkItem]> bookmarks;
    in property <string> status-text: "Готов";
    in property <string> detail-title: "";
    in property <string> detail-url: "";
    in property <string> detail-note: "";

    // Dialog flags
    in-out property <bool> show-folder-dlg: false;
    in-out property <bool> show-bookmark-dlg: false;
    in-out property <bool> show-rename-dlg: false;
    in-out property <bool> show-edit-dlg: false;
    in-out property <string> rename-prefill: "";
    in-out property <string> edit-title-val: "";
    in-out property <string> edit-url-val: "";
    in-out property <string> edit-note-val: "";

    // Navigation callbacks
    callback folder-clicked(int);
    callback folder-toggle(int);
    callback bookmark-clicked(int);
    callback bookmark-open(string);

    // CRUD callbacks
    callback new-folder-confirmed(string);
    callback new-bookmark-confirmed(string, string);
    callback rename-requested();
    callback rename-confirmed(string);
    callback edit-requested();
    callback edit-confirmed(string, string, string);
    callback delete-selected();

    // DB & import/export
    callback open-db();
    callback new-db();
    callback export-html();
    callback export-txt();
    callback import-uadat();
    callback import-html();

    // Search
    callback search-changed(string);

    // ── Keyboard
    forward-focus: main-focus;
    main-focus := FocusScope {
        key-pressed(e) => {
            if e.text == Key.Delete   { root.delete-selected(); return accept; }
            if e.text == Key.F2       { root.rename-requested(); return accept; }
            if e.text == Key.F4       { root.edit-requested(); return accept; }
            if e.text == Key.Return   { if root.detail-url != "" { root.bookmark-open(root.detail-url); } return accept; }
            reject
        }

        VerticalBox {
            padding: 0px;
            spacing: 0px;

            // ── Toolbar (single row)
            Rectangle {
                height: 36px;
                background: #f0f0f0;

                HorizontalBox {
                    padding: 4px;
                    spacing: 3px;
                    alignment: start;

                    Button { text: "БД: Новая";   clicked => { root.new-db(); } }
                    Button { text: "БД: Открыть"; clicked => { root.open-db(); } }

                    Rectangle { width: 1px; background: #ccc; }

                    Button { text: "+ Папка";  clicked => { root.show-folder-dlg = true; } }
                    Button { text: "+ Ссылка"; clicked => { root.show-bookmark-dlg = true; } }
                    Button { text: "Ред. F4";  clicked => { root.edit-requested(); } }
                    Button { text: "Имя F2";   clicked => { root.rename-requested(); } }
                    Button { text: "Удалить";  clicked => { root.delete-selected(); } }

                    Rectangle { width: 1px; background: #ccc; }

                    Button { text: "→ HTML";    clicked => { root.export-html(); } }
                    Button { text: "→ TXT";     clicked => { root.export-txt(); } }
                    Button { text: "← ua.dat";  clicked => { root.import-uadat(); } }
                    Button { text: "← HTML";    clicked => { root.import-html(); } }

                    Rectangle { horizontal-stretch: 1; }

                    LineEdit {
                        width: 180px;
                        placeholder-text: "Поиск (Ctrl+F)";
                        edited => { root.search-changed(self.text); }
                    }
                }
            }

            // ── Main area
            HorizontalBox {
                padding: 0px;
                spacing: 0px;
                vertical-stretch: 1;

                // Left: folder tree
                Rectangle {
                    width: 210px;
                    background: #fafafa;
                    border-color: #e0e0e0;
                    border-width: 1px;

                    ScrollView {
                        VerticalBox {
                            padding: 4px;
                            spacing: 1px;
                            alignment: start;

                            for f in root.folders: Rectangle {
                                height: 24px;
                                background: f.selected ? #0078d4 : transparent;
                                border-radius: 3px;

                                TouchArea { clicked => { root.folder-clicked(f.id); } }

                                HorizontalBox {
                                    padding-left: f.depth * 14px + 2px;
                                    padding-right: 4px;
                                    padding-top: 2px;
                                    padding-bottom: 2px;
                                    spacing: 3px;

                                    Rectangle {
                                        width: 14px;
                                        background: transparent;
                                        Text {
                                            text: f.has-children ? (f.expanded ? "v" : ">") : " ";
                                            color: f.selected ? #ffffff : #aaaaaa;
                                            font-size: 9px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                        TouchArea { clicked => { root.folder-toggle(f.id); } }
                                    }

                                    Text {
                                        text: f.title;
                                        color: f.selected ? #ffffff : #1a1a1a;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                }
                            }
                        }
                    }
                }

                // Right: list + detail
                VerticalBox {
                    padding: 0px;
                    spacing: 0px;
                    horizontal-stretch: 1;

                    // Column headers
                    Rectangle {
                        height: 22px;
                        background: #f0f0f0;
                        border-color: #ddd;
                        border-width: 1px;

                        HorizontalBox {
                            padding-left: 6px;
                            spacing: 0px;
                            Text { text: "Название"; font-size: 11px; color: #666; width: 250px; vertical-alignment: center; }
                            Text { text: "URL";      font-size: 11px; color: #666; vertical-alignment: center; }
                        }
                    }

                    // Bookmark list
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalBox {
                            padding: 4px;
                            spacing: 1px;
                            alignment: start;

                            for b in root.bookmarks: Rectangle {
                                height: 22px;
                                background: b.selected ? #0078d4 : transparent;
                                border-radius: 2px;

                                TouchArea {
                                    clicked => { root.bookmark-clicked(b.id); }
                                    double-clicked => { root.bookmark-open(b.url); }
                                }

                                HorizontalBox {
                                    padding-left: 6px;
                                    padding-right: 4px;
                                    padding-top: 2px;
                                    padding-bottom: 2px;
                                    spacing: 0px;

                                    Text {
                                        text: b.title;
                                        color: b.selected ? #ffffff : #1a1a1a;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        width: 250px;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: b.url;
                                        color: b.selected ? #bbddff : #0055cc;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                }
                            }
                        }
                    }

                    // Detail panel
                    if root.detail-url != "": Rectangle {
                        height: 54px;
                        background: #f0f4ff;
                        border-color: #b8caf0;
                        border-width: 1px;

                        VerticalBox {
                            padding: 6px;
                            spacing: 2px;

                            Text {
                                text: root.detail-title;
                                font-size: 13px;
                                font-weight: 700;
                                color: #111;
                                overflow: elide;
                            }
                            Text {
                                text: root.detail-url;
                                font-size: 11px;
                                color: #0044aa;
                                overflow: elide;
                            }
                            if root.detail-note != "": Text {
                                text: root.detail-note;
                                font-size: 11px;
                                color: #555;
                                overflow: elide;
                            }
                        }
                    }
                }
            }

            // Status bar
            Rectangle {
                height: 20px;
                background: #f0f0f0;
                border-color: #ddd;
                border-width: 1px;
                HorizontalBox {
                    padding-left: 8px;
                    Text { text: root.status-text; font-size: 11px; color: #555; vertical-alignment: center; }
                }
            }
        }
    }

    // ══ Dialogs ════════════════════════════════════════════════════════════════

    // New Folder
    if root.show-folder-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-folder-dlg = false; } }
        Rectangle {
            width: 320px; height: 140px; background: #fff;
            border-radius: 6px; border-color: #ccc; border-width: 1px;
            drop-shadow-blur: 12px; drop-shadow-color: #30000000;
            VerticalBox {
                padding: 16px; spacing: 12px;
                Text { text: "Новая папка"; font-size: 14px; font-weight: 700; }
                fn-in := LineEdit { placeholder-text: "Название"; }
                HorizontalBox {
                    spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-folder-dlg = false; } }
                    Button { text: "Создать"; primary: true;
                        clicked => { if fn-in.text != "" { root.new-folder-confirmed(fn-in.text); root.show-folder-dlg = false; } } }
                }
            }
        }
    }

    // New Bookmark
    if root.show-bookmark-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-bookmark-dlg = false; } }
        Rectangle {
            width: 400px; height: 185px; background: #fff;
            border-radius: 6px; border-color: #ccc; border-width: 1px;
            drop-shadow-blur: 12px; drop-shadow-color: #30000000;
            VerticalBox {
                padding: 16px; spacing: 10px;
                Text { text: "Новая ссылка"; font-size: 14px; font-weight: 700; }
                bm-url := LineEdit { placeholder-text: "URL (https://...)"; }
                bm-ttl := LineEdit { placeholder-text: "Название (необязательно)"; }
                HorizontalBox {
                    spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-bookmark-dlg = false; } }
                    Button { text: "Добавить"; primary: true;
                        clicked => { if bm-url.text != "" { root.new-bookmark-confirmed(bm-ttl.text, bm-url.text); root.show-bookmark-dlg = false; } } }
                }
            }
        }
    }

    // Edit Bookmark (F4)
    if root.show-edit-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-edit-dlg = false; } }
        Rectangle {
            width: 440px; height: 250px; background: #fff;
            border-radius: 6px; border-color: #ccc; border-width: 1px;
            drop-shadow-blur: 12px; drop-shadow-color: #30000000;
            VerticalBox {
                padding: 16px; spacing: 10px;
                Text { text: "Свойства ссылки"; font-size: 14px; font-weight: 700; }
                ed-ttl  := LineEdit { text: root.edit-title-val; placeholder-text: "Название"; }
                ed-url  := LineEdit { text: root.edit-url-val;   placeholder-text: "URL"; }
                ed-note := LineEdit { text: root.edit-note-val;  placeholder-text: "Заметка (необязательно)"; }
                HorizontalBox {
                    spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-edit-dlg = false; } }
                    Button { text: "Сохранить"; primary: true;
                        clicked => {
                            root.edit-confirmed(ed-ttl.text, ed-url.text, ed-note.text);
                            root.show-edit-dlg = false;
                        }
                    }
                }
            }
        }
    }

    // Rename
    if root.show-rename-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-rename-dlg = false; } }
        Rectangle {
            width: 340px; height: 140px; background: #fff;
            border-radius: 6px; border-color: #ccc; border-width: 1px;
            drop-shadow-blur: 12px; drop-shadow-color: #30000000;
            VerticalBox {
                padding: 16px; spacing: 12px;
                Text { text: "Переименовать"; font-size: 14px; font-weight: 700; }
                rn-in := LineEdit { text: root.rename-prefill; placeholder-text: "Новое название"; }
                HorizontalBox {
                    spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-rename-dlg = false; } }
                    Button { text: "ОК"; primary: true;
                        clicked => { if rn-in.text != "" { root.rename-confirmed(rn-in.text); root.show-rename-dlg = false; } } }
                }
            }
        }
    }
}
