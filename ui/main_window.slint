import { Button, HorizontalBox, VerticalBox, LineEdit, ScrollView } from "std-widgets.slint";

export struct FolderNode {
    id: int,
    title: string,
    depth: int,
    expanded: bool,
    has-children: bool,
    selected: bool,
}

export struct BookmarkItem {
    id: int,
    title: string,
    url: string,
    note: string,
    favicon: image,
    has-favicon: bool,
    check-status: string,   // "" | "OK" | "404" | "Err"
    selected: bool,
}

export component MainWindow inherits Window {
    title: "URL Album 3 — " + root.db-name;
    preferred-width: 960px;
    preferred-height: 640px;
    min-width: 500px;
    min-height: 350px;
    background: #ffffff;

    // Data
    in property <[FolderNode]> folders;
    in property <[BookmarkItem]> bookmarks;
    in property <string> status-text: "Готов";
    in property <string> detail-title: "";
    in property <string> detail-url: "";
    in property <string> detail-note: "";
    in property <string> sort-label: "Название ↑";
    in property <string> db-name: "album.db";

    // Tree width (resizable, stored as int pixels)
    in-out property <int> tree-width-px: 210;
    property <length> tree-width: root.tree-width-px * 1px;

    // Dialog flags
    in-out property <bool> show-folder-dlg: false;
    in-out property <bool> show-bookmark-dlg: false;
    in-out property <bool> show-rename-dlg: false;
    in-out property <bool> show-edit-dlg: false;
    in-out property <bool> show-move-dlg: false;
    in-out property <string> rename-prefill: "";
    in-out property <string> edit-title-val: "";
    in-out property <string> edit-url-val: "";
    in-out property <string> edit-note-val: "";

    // Context menu
    in-out property <bool> show-ctx: false;
    in-out property <bool> ctx-is-folder: false;
    in-out property <int>  ctx-id: 0;

    // Callbacks — navigation
    callback folder-clicked(int);
    callback folder-toggle(int);
    callback bookmark-clicked(int);
    callback bookmark-open(string);
    callback bookmark-nav(int);  // +1 or -1 arrow key

    // Callbacks — CRUD
    callback new-folder-confirmed(string);
    callback new-bookmark-confirmed(string, string);
    callback rename-requested();
    callback rename-confirmed(string);
    callback edit-requested();
    callback edit-confirmed(string, string, string);
    callback delete-selected();

    // Callbacks — context menu actions
    callback ctx-open(int);
    callback ctx-edit(int);
    callback ctx-rename(int);
    callback ctx-delete(int);
    callback ctx-new-sub(int);
    callback ctx-new-bm-in(int);
    callback ctx-copy-url(int);
    callback ctx-move(int);
    callback ctx-move-confirm(int);

    // Callbacks — DB & files
    callback open-db();
    callback new-db();
    callback backup-db();
    callback export-html();
    callback export-txt();
    callback import-uadat();
    callback import-html();
    callback import-browser();

    // Callbacks — other
    callback search-changed(string);
    callback sort-toggle();
    callback tree-width-changed(int);
    callback load-favicons();
    callback focus-search();
    callback check-links();
    callback find-duplicates();

    callback folder-right-click(int);
    callback bookmark-right-click(int);

    // ── Keyboard
    forward-focus: main-focus;
    main-focus := FocusScope {
        key-pressed(e) => {
            if e.text == Key.Delete   { root.delete-selected(); return accept; }
            if e.text == Key.F2       { root.rename-requested(); return accept; }
            if e.text == Key.F4       { root.edit-requested(); return accept; }
            if e.text == Key.Return   { if root.detail-url != "" { root.bookmark-open(root.detail-url); } return accept; }
            if e.text == Key.UpArrow  { root.bookmark-nav(-1); return accept; }
            if e.text == Key.DownArrow{ root.bookmark-nav(1);  return accept; }
            if e.modifiers.control && e.text == "f" { search-box.focus(); return accept; }
            reject
        }

        VerticalBox {
            padding: 0px;
            spacing: 0px;

            // ── Toolbar row 1
            Rectangle {
                height: 34px;
                background: #f5f5f5;
                HorizontalBox {
                    padding: 4px; spacing: 4px; alignment: start;
                    Button { text: "+ Папка";       clicked => { root.show-folder-dlg = true; } }
                    Button { text: "+ Ссылка";      clicked => { root.show-bookmark-dlg = true; } }
                    Button { text: "Ред. [F4]";     clicked => { root.edit-requested(); } }
                    Button { text: "Имя [F2]";      clicked => { root.rename-requested(); } }
                    Button { text: "Удалить [Del]"; clicked => { root.delete-selected(); } }
                    Rectangle { horizontal-stretch: 1; }
                    search-box := LineEdit { width: 190px; placeholder-text: "Поиск... (Ctrl+F)"; edited => { root.search-changed(self.text); } }
                }
            }

            // ── Toolbar row 2
            Rectangle {
                height: 30px;
                background: #eeeeee;
                HorizontalBox {
                    padding: 3px; spacing: 3px; alignment: start;
                    Button { text: "БД: Новая";   clicked => { root.new-db(); } }
                    Button { text: "БД: Открыть"; clicked => { root.open-db(); } }
                    Button { text: "БД: Копия";   clicked => { root.backup-db(); } }
                    Rectangle { width: 4px; }
                    Button { text: "→ HTML"; clicked => { root.export-html(); } }
                    Button { text: "→ TXT";  clicked => { root.export-txt(); } }
                    Rectangle { width: 4px; }
                    Button { text: "← ua.dat";   clicked => { root.import-uadat(); } }
                    Button { text: "← HTML";     clicked => { root.import-html(); } }
                    Button { text: "← Браузер";  clicked => { root.import-browser(); } }
                    Rectangle { width: 4px; }
                    Button { text: "Favicons"; clicked => { root.load-favicons(); } }
                    Button { text: "Проверка"; clicked => { root.check-links(); } }
                    Button { text: "Дубли";    clicked => { root.find-duplicates(); } }
                }
            }

            // ── Main area
            HorizontalBox {
                padding: 0px; spacing: 0px; vertical-stretch: 1;

                // Left: folder tree
                Rectangle {
                    width: root.tree-width;
                    background: #fafafa;
                    border-color: #e0e0e0;
                    border-width: 1px;

                    ScrollView {
                        VerticalBox {
                            padding: 4px; spacing: 1px; alignment: start;

                            for f in root.folders: Rectangle {
                                height: 24px;
                                background: f.selected ? #0078d4 : transparent;
                                border-radius: 3px;

                                // Left-click
                                left-ta := TouchArea {
                                    clicked => { root.folder-clicked(f.id); }
                                }

                                right-ta := TouchArea {
                                    pointer-event(e) => {
                                        if e.button == PointerEventButton.right && e.kind == PointerEventKind.down {
                                            root.folder-right-click(f.id);
                                        }
                                    }
                                }

                                HorizontalBox {
                                    padding-left: f.depth * 14px + 2px;
                                    padding-right: 4px; padding-top: 2px; padding-bottom: 2px;
                                    spacing: 3px;

                                    Rectangle {
                                        width: 14px; background: transparent;
                                        Text {
                                            text: f.has-children ? (f.expanded ? "v" : ">") : " ";
                                            color: f.selected ? #ffffff : #aaaaaa;
                                            font-size: 9px;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                        TouchArea { clicked => { root.folder-toggle(f.id); } }
                                    }
                                    Text {
                                        text: f.title;
                                        color: f.selected ? #ffffff : #1a1a1a;
                                        font-size: 13px; vertical-alignment: center;
                                        overflow: elide; horizontal-stretch: 1;
                                    }
                                }
                            }
                        }
                    }
                }

                // Splitter
                Rectangle {
                    width: 4px;
                    background: #e0e0e0;
                    splitter-ta := TouchArea {
                        mouse-cursor: col-resize;
                        moved => {
                            root.tree-width-px = max(100, min(500, root.tree-width-px + round(self.mouse-x / 1px)));
                            root.tree-width-changed(root.tree-width-px);
                        }
                    }
                }

                // Right: list + detail
                VerticalBox {
                    padding: 0px; spacing: 0px; horizontal-stretch: 1;

                    // Column headers with sort
                    Rectangle {
                        height: 22px;
                        background: #f0f0f0;
                        border-color: #ddd;
                        border-width: 1px;

                        HorizontalBox {
                            padding-left: 6px; spacing: 0px;
                            Text { text: "Название"; font-size: 11px; color: #555; width: 250px; vertical-alignment: center; }
                            Text { text: "URL"; font-size: 11px; color: #555; horizontal-stretch: 1; vertical-alignment: center; }
                            Rectangle { width: 4px; }
                            Button {
                                text: root.sort-label;
                                clicked => { root.sort-toggle(); }
                            }
                            Rectangle { width: 4px; }
                        }
                    }

                    // Bookmark list
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalBox {
                            padding: 4px; spacing: 1px; alignment: start;

                            for b in root.bookmarks: Rectangle {
                                height: 22px;
                                background: b.selected ? #0078d4 : transparent;
                                border-radius: 2px;

                                bm-left := TouchArea {
                                    clicked => { root.bookmark-clicked(b.id); }
                                    double-clicked => { root.bookmark-open(b.url); }
                                }

                                TouchArea {
                                    pointer-event(e) => {
                                        if e.button == PointerEventButton.right && e.kind == PointerEventKind.down {
                                            root.bookmark-right-click(b.id);
                                        }
                                    }
                                }

                                HorizontalBox {
                                    padding-left: 4px; padding-right: 4px;
                                    padding-top: 2px; padding-bottom: 2px; spacing: 3px;

                                    // Favicon or dot
                                    Rectangle {
                                        width: 16px;
                                        if b.has-favicon: Image {
                                            source: b.favicon;
                                            width: 16px; height: 16px;
                                            image-rendering: pixelated;
                                        }
                                        if !b.has-favicon: Text {
                                            text: ".";
                                            color: b.selected ? #aaccff : #999999;
                                            font-size: 18px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    Text { text: b.title; color: b.selected ? #ffffff : #1a1a1a;
                                        font-size: 13px; vertical-alignment: center; width: 234px; overflow: elide; }
                                    Text { text: b.url; color: b.selected ? #bbddff : #0055cc;
                                        font-size: 12px; vertical-alignment: center; overflow: elide; horizontal-stretch: 1; }

                                    // Check status badge
                                    if b.check-status != "": Rectangle {
                                        width: 30px;
                                        background: b.check-status == "OK" ? #22aa44 : #cc2200;
                                        border-radius: 3px;
                                        Text {
                                            text: b.check-status;
                                            color: white; font-size: 10px;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Detail panel
                    if root.detail-url != "": Rectangle {
                        height: 54px; background: #f0f4ff;
                        border-color: #b8caf0; border-width: 1px;
                        VerticalBox {
                            padding: 6px; spacing: 2px;
                            Text { text: root.detail-title; font-size: 13px; font-weight: 700; color: #111; overflow: elide; }
                            Text { text: root.detail-url; font-size: 11px; color: #0044aa; overflow: elide; }
                            if root.detail-note != "": Text { text: root.detail-note; font-size: 11px; color: #555; overflow: elide; }
                        }
                    }
                }
            }

            // Status bar
            Rectangle {
                height: 20px; background: #f0f0f0; border-color: #ddd; border-width: 1px;
                HorizontalBox {
                    padding-left: 8px;
                    Text { text: root.status-text; font-size: 11px; color: #555; vertical-alignment: center; }
                }
            }
        }
    }

    // ══ Context menu overlay ══════════════════════════════════════════════════
    if root.show-ctx: Rectangle {
        background: transparent;
        TouchArea { clicked => { root.show-ctx = false; } }

        Rectangle {
            x: root.ctx-is-folder ? 215px : 450px;
            y: 90px;
            width: 185px;
            background: #ffffff;
            border-color: #aaa;
            border-width: 1px;
            drop-shadow-blur: 8px;
            drop-shadow-color: #30000000;

            VerticalBox {
                padding: 2px; spacing: 0px;

                if root.ctx-is-folder: Rectangle {
                    height: 24px; border-radius: 2px;
                    background: folder-open-ta.has-hover ? #0078d4 : transparent;
                    folder-open-ta := TouchArea {
                        clicked => { root.show-ctx = false; root.folder-clicked(root.ctx-id); }
                    }
                    Text { text: "Открыть"; x: 8px; font-size: 13px;
                        color: folder-open-ta.has-hover ? #fff : #1a1a1a; vertical-alignment: center; }
                }

                if root.ctx-is-folder: Rectangle {
                    height: 24px; border-radius: 2px;
                    background: ns-ta.has-hover ? #0078d4 : transparent;
                    ns-ta := TouchArea { clicked => { root.show-ctx = false; root.ctx-new-sub(root.ctx-id); } }
                    Text { text: "+ Подпапка"; x: 8px; font-size: 13px;
                        color: ns-ta.has-hover ? #fff : #1a1a1a; vertical-alignment: center; }
                }

                if root.ctx-is-folder: Rectangle {
                    height: 24px; border-radius: 2px;
                    background: nb-ta.has-hover ? #0078d4 : transparent;
                    nb-ta := TouchArea { clicked => { root.show-ctx = false; root.ctx-new-bm-in(root.ctx-id); } }
                    Text { text: "+ Ссылка в папку"; x: 8px; font-size: 13px;
                        color: nb-ta.has-hover ? #fff : #1a1a1a; vertical-alignment: center; }
                }

                if !root.ctx-is-folder: Rectangle {
                    height: 24px; border-radius: 2px;
                    background: bm-open-ta.has-hover ? #0078d4 : transparent;
                    bm-open-ta := TouchArea { clicked => { root.show-ctx = false; root.ctx-open(root.ctx-id); } }
                    Text { text: "Открыть URL"; x: 8px; font-size: 13px;
                        color: bm-open-ta.has-hover ? #fff : #1a1a1a; vertical-alignment: center; }
                }

                if !root.ctx-is-folder: Rectangle {
                    height: 24px; border-radius: 2px;
                    background: bm-edit-ta.has-hover ? #0078d4 : transparent;
                    bm-edit-ta := TouchArea { clicked => { root.show-ctx = false; root.ctx-edit(root.ctx-id); } }
                    Text { text: "Свойства [F4]"; x: 8px; font-size: 13px;
                        color: bm-edit-ta.has-hover ? #fff : #1a1a1a; vertical-alignment: center; }
                }

                if !root.ctx-is-folder: Rectangle {
                    height: 24px; border-radius: 2px;
                    background: bm-copy-ta.has-hover ? #0078d4 : transparent;
                    bm-copy-ta := TouchArea { clicked => { root.show-ctx = false; root.ctx-copy-url(root.ctx-id); } }
                    Text { text: "Копировать URL"; x: 8px; font-size: 13px;
                        color: bm-copy-ta.has-hover ? #fff : #1a1a1a; vertical-alignment: center; }
                }

                if !root.ctx-is-folder: Rectangle {
                    height: 24px; border-radius: 2px;
                    background: bm-move-ta.has-hover ? #0078d4 : transparent;
                    bm-move-ta := TouchArea { clicked => { root.show-ctx = false; root.ctx-move(root.ctx-id); } }
                    Text { text: "Переместить в..."; x: 8px; font-size: 13px;
                        color: bm-move-ta.has-hover ? #fff : #1a1a1a; vertical-alignment: center; }
                }

                // Separator
                Rectangle { height: 1px; background: #ddd; }

                // Common: rename
                Rectangle {
                    height: 24px; border-radius: 2px;
                    background: rn-ta.has-hover ? #0078d4 : transparent;
                    rn-ta := TouchArea { clicked => { root.show-ctx = false; root.ctx-rename(root.ctx-id); } }
                    Text { text: "Переименовать [F2]"; x: 8px; font-size: 13px;
                        color: rn-ta.has-hover ? #fff : #1a1a1a; vertical-alignment: center; }
                }

                // Common: delete
                Rectangle {
                    height: 24px; border-radius: 2px;
                    background: del-ta.has-hover ? #cc2200 : transparent;
                    del-ta := TouchArea { clicked => { root.show-ctx = false; root.ctx-delete(root.ctx-id); } }
                    Text { text: "Удалить [Del]"; x: 8px; font-size: 13px;
                        color: del-ta.has-hover ? #fff : #cc2200; vertical-alignment: center; }
                }
            }
        }
    }

    // ══ CRUD Dialogs ═══════════════════════════════════════════════════════════

    if root.show-folder-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-folder-dlg = false; } }
        Rectangle {
            width: 320px; height: 140px; background: #fff; border-radius: 6px; border-color: #ccc; border-width: 1px; drop-shadow-blur: 12px; drop-shadow-color: #30000000;
            VerticalBox { padding: 16px; spacing: 12px;
                Text { text: "Новая папка"; font-size: 14px; font-weight: 700; }
                fn-in := LineEdit { placeholder-text: "Название"; }
                HorizontalBox { spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-folder-dlg = false; } }
                    Button { text: "Создать"; primary: true;
                        clicked => { if fn-in.text != "" { root.new-folder-confirmed(fn-in.text); root.show-folder-dlg = false; } } } } }
        }
    }

    if root.show-bookmark-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-bookmark-dlg = false; } }
        Rectangle {
            width: 400px; height: 185px; background: #fff; border-radius: 6px; border-color: #ccc; border-width: 1px; drop-shadow-blur: 12px; drop-shadow-color: #30000000;
            VerticalBox { padding: 16px; spacing: 10px;
                Text { text: "Новая ссылка"; font-size: 14px; font-weight: 700; }
                bm-url := LineEdit { placeholder-text: "URL (https://...)"; }
                bm-ttl := LineEdit { placeholder-text: "Название (необязательно)"; }
                HorizontalBox { spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-bookmark-dlg = false; } }
                    Button { text: "Добавить"; primary: true;
                        clicked => { if bm-url.text != "" { root.new-bookmark-confirmed(bm-ttl.text, bm-url.text); root.show-bookmark-dlg = false; } } } } }
        }
    }

    if root.show-edit-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-edit-dlg = false; } }
        Rectangle {
            width: 440px; height: 250px; background: #fff; border-radius: 6px; border-color: #ccc; border-width: 1px; drop-shadow-blur: 12px; drop-shadow-color: #30000000;
            VerticalBox { padding: 16px; spacing: 10px;
                Text { text: "Свойства ссылки"; font-size: 14px; font-weight: 700; }
                ed-ttl  := LineEdit { text: root.edit-title-val; placeholder-text: "Название"; }
                ed-url  := LineEdit { text: root.edit-url-val;   placeholder-text: "URL"; }
                ed-note := LineEdit { text: root.edit-note-val;  placeholder-text: "Заметка"; }
                HorizontalBox { spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-edit-dlg = false; } }
                    Button { text: "Сохранить"; primary: true;
                        clicked => { root.edit-confirmed(ed-ttl.text, ed-url.text, ed-note.text); root.show-edit-dlg = false; } } } }
        }
    }

    // Move to folder dialog
    if root.show-move-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-move-dlg = false; } }
        Rectangle {
            width: 320px; height: 380px; background: #fff; border-radius: 6px;
            border-color: #ccc; border-width: 1px; drop-shadow-blur: 12px; drop-shadow-color: #30000000;
            VerticalBox {
                padding: 12px; spacing: 8px;
                Text { text: "Переместить в папку"; font-size: 14px; font-weight: 700; }
                ScrollView {
                    vertical-stretch: 1;
                    VerticalBox {
                        padding: 4px; spacing: 1px; alignment: start;
                        for f in root.folders: Rectangle {
                            height: 24px;
                            background: move-item-ta.has-hover ? #0078d4 : transparent;
                            border-radius: 2px;
                            move-item-ta := TouchArea {
                                clicked => {
                                    root.ctx-move-confirm(f.id);
                                    root.show-move-dlg = false;
                                }
                            }
                            HorizontalBox {
                                padding-left: f.depth * 12px + 4px; padding-right: 4px;
                                padding-top: 2px; padding-bottom: 2px;
                                Text { text: f.title; font-size: 13px;
                                    color: move-item-ta.has-hover ? #fff : #1a1a1a;
                                    vertical-alignment: center; overflow: elide; }
                            }
                        }
                    }
                }
                HorizontalBox {
                    alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-move-dlg = false; } }
                }
            }
        }
    }

    if root.show-rename-dlg: Rectangle {
        background: #88000000;
        TouchArea { clicked => { root.show-rename-dlg = false; } }
        Rectangle {
            width: 340px; height: 140px; background: #fff; border-radius: 6px; border-color: #ccc; border-width: 1px; drop-shadow-blur: 12px; drop-shadow-color: #30000000;
            VerticalBox { padding: 16px; spacing: 12px;
                Text { text: "Переименовать"; font-size: 14px; font-weight: 700; }
                rn-in := LineEdit { text: root.rename-prefill; placeholder-text: "Новое название"; }
                HorizontalBox { spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-rename-dlg = false; } }
                    Button { text: "ОК"; primary: true;
                        clicked => { if rn-in.text != "" { root.rename-confirmed(rn-in.text); root.show-rename-dlg = false; } } } } }
        }
    }
}
