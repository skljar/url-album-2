import { Button, HorizontalBox, VerticalBox, LineEdit, ScrollView } from "std-widgets.slint";

export global Icons {
    out property <image> folder-closed: @image-url("icons/folder-closed.png");
    out property <image> folder-open:   @image-url("icons/folder-open.png");
}

// Unified tree node: kind=0 folder, kind=1 bookmark
export struct TreeNode {
    id: int,
    kind: int,
    title: string,
    url: string,
    depth: int,
    expanded: bool,
    has-children: bool,
    selected: bool,
    count: int,
    favicon: image,
    has-favicon: bool,
}

// Unified right-panel item: folders + bookmarks
export struct RightItem {
    id: int,
    kind: int,      // 0=folder, 1=bookmark
    title: string,
    url: string,
    note: string,
    favicon: image,
    has-favicon: bool,
    check-status: string,
    count: int,     // folder bookmark count
    selected: bool,
}

export struct BookmarkItem {
    id: int,
    title: string,
    url: string,
    note: string,
    favicon: image,
    has-favicon: bool,
    check-status: string,
    selected: bool,
}

component MenuItem inherits Rectangle {
    in property <string> text;
    in property <bool> separator: false;
    callback clicked;
    height: separator ? 5px : 22px;
    background: ta.has-hover && !separator ? #0078d4 : transparent;
    if separator: Rectangle { height: 1px; background: #ddd; y: 2px; }
    if !separator: Text { text: root.text; color: ta.has-hover ? white : #111; font-size: 13px; x: 12px; vertical-alignment: center; }
    ta := TouchArea { enabled: !root.separator; clicked => { root.clicked(); } }
}

component MenuBarItem inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked;
    height: 22px;
    width: text.character-count * 8px + 16px;
    background: root.active ? #e0e0e0 : (ta.has-hover ? #e8e8e8 : transparent);
    Text { text: root.text; font-size: 13px; color: #111; horizontal-alignment: center; vertical-alignment: center; }
    ta := TouchArea { clicked => { root.clicked(); } }
}

export component MainWindow inherits Window {
    title: "URL Album 3 — " + root.db-name;
    preferred-width: 960px;
    preferred-height: 640px;
    min-width: 500px; min-height: 350px;
    background: #ffffff;

    // Data
    in property <[TreeNode]>    tree-nodes;
    in property <[RightItem]>   right-items;
    in property <[BookmarkItem]> bookmarks;
    in property <string> status-text: "Готов";
    in property <string> breadcrumb: "";
    in property <string> detail-title: "";
    in property <string> detail-url: "";
    in property <string> detail-note: "";
    in property <image>  detail-favicon;
    in property <bool>   detail-has-favicon: false;
    in property <string> sort-label: "Название ↑";
    in property <string> db-name: "album.db";
    in property <int>    active-bookmark: 0;

    // Favicon progress panel
    in property <bool>   show-favicon-progress: false;
    in property <string> favicon-progress-text: "";
    in property <float>  favicon-progress-value: 0.0;

    // Dialogs
    in-out property <bool>   show-folder-dlg: false;
    in-out property <bool>   show-bookmark-dlg: false;
    in-out property <bool>   show-rename-dlg: false;
    in-out property <bool>   show-edit-dlg: false;
    in-out property <bool>   show-move-dlg: false;
    in-out property <bool>   show-confirm-delete: false;
    in-out property <string> confirm-delete-text: "";
    in-out property <string> rename-prefill: "";
    in-out property <string> edit-title-val: "";
    in-out property <string> edit-url-val: "";
    in-out property <string> edit-note-val: "";

    // Context menu
    in-out property <bool> show-ctx: false;
    in-out property <bool> ctx-is-folder: false;
    in-out property <int>  ctx-id: 0;

    // Menu
    in-out property <string> active-menu: "";

    // Tree width
    in-out property <int> tree-width-px: 240;
    property <length> tree-width: root.tree-width-px * 1px;

    // ── Callbacks ──────────────────────────────────────────────────────────
    callback tree-folder-clicked(int);
    callback tree-folder-toggled(int);
    callback tree-bookmark-clicked(int);
    callback right-folder-clicked(int);     // navigate into subfolder in right panel
    callback right-bookmark-clicked(int);   // click bookmark in right panel → detail
    callback bookmark-open(string);
    callback bookmark-nav(int);
    callback back-to-list();

    callback new-folder-confirmed(string);
    callback new-bookmark-confirmed(string, string, string);  // title, url, note
    callback confirm-delete-yes();
    callback expand-all(); callback collapse-all();
    callback rename-requested();
    callback rename-confirmed(string);
    callback edit-requested();
    callback edit-confirmed(string, string, string);
    callback delete-selected();

    callback ctx-open(int); callback ctx-edit(int); callback ctx-rename(int);
    callback ctx-delete(int); callback ctx-new-sub(int); callback ctx-new-bm-in(int);
    callback ctx-copy-url(int); callback ctx-move(int); callback ctx-move-confirm(int);
    callback ctx-export-folder(int); callback ctx-load-favicons-folder(int);
    callback folder-right-click(int); callback bookmark-right-click(int);

    callback open-db(); callback new-db(); callback backup-db();
    callback export-html(); callback export-txt();
    callback import-uadat(); callback import-html(); callback import-browser();
    callback search-changed(string); callback sort-toggle();
    callback load-favicons(); callback check-links(); callback find-duplicates(); callback show-all();
    callback tree-width-changed(int); callback focus-search();

    // ── Keyboard ───────────────────────────────────────────────────────────
    forward-focus: main-focus;
    main-focus := FocusScope {
        key-pressed(e) => {
            if e.text == Key.Delete    { root.delete-selected(); return accept; }
            if e.text == Key.F2        { root.rename-requested(); return accept; }
            if e.text == Key.F4        { root.edit-requested(); return accept; }
            if e.text == Key.Return    { if root.detail-url != "" { root.bookmark-open(root.detail-url); } return accept; }
            if e.text == Key.Escape    {
                root.active-menu = "";
                root.show-ctx = false;
                if root.active-bookmark != 0 { root.back-to-list(); return accept; }
                root.search-changed(""); search-input.text = ""; return accept;
            }
            if e.text == Key.UpArrow   { root.bookmark-nav(-1); return accept; }
            if e.text == Key.DownArrow { root.bookmark-nav(1);  return accept; }
            if e.modifiers.control && e.text == "f" { search-input.focus(); return accept; }
            if e.modifiers.control && !e.modifiers.shift && e.text == "n" { root.show-bookmark-dlg = true; return accept; }
            reject
        }

        VerticalBox {
            padding: 0px; spacing: 0px;

            // ── Menubar ────────────────────────────────────────────────────
            Rectangle {
                height: 24px; background: #f0f0f0; border-color: #ccc; border-width: 1px;
                HorizontalBox {
                    padding-left: 2px; padding-right: 2px; padding-top: 1px; padding-bottom: 1px; spacing: 0px; alignment: start;
                    MenuBarItem { text: "Файл";    active: root.active-menu=="file";     clicked => { root.active-menu = root.active-menu=="file" ? "" : "file"; } }
                    MenuBarItem { text: "Ссылки";  active: root.active-menu=="links";    clicked => { root.active-menu = root.active-menu=="links" ? "" : "links"; } }
                    MenuBarItem { text: "Перенос"; active: root.active-menu=="transfer"; clicked => { root.active-menu = root.active-menu=="transfer" ? "" : "transfer"; } }
                    MenuBarItem { text: "Поиск";   active: root.active-menu=="search";   clicked => { root.active-menu = root.active-menu=="search" ? "" : "search"; } }
                    MenuBarItem { text: "Вид";     active: root.active-menu=="view";     clicked => { root.active-menu = root.active-menu=="view" ? "" : "view"; } }
                }
            }

            // ── Toolbar ────────────────────────────────────────────────────
            Rectangle {
                height: 30px; background: #f8f8f8; border-color: #ddd; border-width: 1px;
                HorizontalBox {
                    padding: 3px; spacing: 3px; alignment: start;
                    Button { text: "+ Папка";   clicked => { root.active-menu=""; root.show-folder-dlg = true; } }
                    Button { text: "+ Ссылка";  clicked => { root.active-menu=""; root.show-bookmark-dlg = true; } }
                    Button { text: "Ред. [F4]"; clicked => { root.active-menu=""; root.edit-requested(); } }
                    Button { text: "Имя [F2]";  clicked => { root.active-menu=""; root.rename-requested(); } }
                    Button { text: "Удалить";   clicked => { root.active-menu=""; root.delete-selected(); } }
                    Rectangle { horizontal-stretch: 1; }
                    search-input := LineEdit { width: 190px; placeholder-text: "Поиск... (Ctrl+F)"; edited => { root.search-changed(self.text); } }
                }
            }

            // ── Main area ──────────────────────────────────────────────────
            HorizontalBox {
                padding: 0px; spacing: 0px; vertical-stretch: 1;

                // Left: unified tree (folders + bookmark leaves)
                Rectangle {
                    width: root.tree-width; background: #f9f9f9; border-color: #d8d8d8; border-width: 1px;

                    ScrollView {
                        VerticalBox {
                            padding: 2px; spacing: 0px; alignment: start;

                            for node in root.tree-nodes: Rectangle {
                                height: 22px;
                                background: node.selected ? #0078d4 : transparent;
                                border-radius: 2px;

                                // Клик = выбрать (без раскрытия)
                                // Двойной клик = toggle expand (только папки)
                                // Правый клик = контекстное меню
                                TouchArea {
                                    clicked => {
                                        if node.kind == 0 { root.tree-folder-clicked(node.id); }
                                        else { root.tree-bookmark-clicked(node.id); }
                                    }
                                    double-clicked => {
                                        if node.kind == 0 { root.tree-folder-toggled(node.id); }
                                        else { root.bookmark-open(node.url); }
                                    }
                                    pointer-event(e) => {
                                        if e.button == PointerEventButton.right && e.kind == PointerEventKind.down {
                                            if node.kind == 0 { root.folder-right-click(node.id); }
                                            else { root.bookmark-right-click(node.id); }
                                        }
                                    }
                                }

                                HorizontalBox {
                                    padding-left: node.depth * 14px + 2px;
                                    padding-right: 2px; padding-top: 1px; padding-bottom: 1px;
                                    spacing: 3px;

                                    // [+]/[-] for folders, spacer for bookmarks
                                    if node.kind == 0: Rectangle {
                                        width: 16px; height: 16px;
                                        border-color: node.has-children ? (node.selected ? #ffffff60 : #aaa) : transparent;
                                        border-width: node.has-children ? 1px : 0px;
                                        border-radius: 2px; background: transparent;
                                        if node.has-children: Text {
                                            text: node.expanded ? "-" : "+";
                                            color: node.selected ? white : #555;
                                            font-size: 12px; font-weight: 700;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                        TouchArea { clicked => { root.tree-folder-toggled(node.id); } }
                                    }
                                    if node.kind == 1: Rectangle { width: 16px; }  // indent spacer

                                    // Folder icon / favicon / dot
                                    if node.kind == 0: Image {
                                        source: node.expanded ? Icons.folder-open : Icons.folder-closed;
                                        width: 16px; height: 16px; image-rendering: pixelated;
                                    }
                                    if node.kind == 1 && node.has-favicon: Image {
                                        source: node.favicon;
                                        width: 16px; height: 16px; image-rendering: pixelated;
                                    }
                                    if node.kind == 1 && !node.has-favicon: Text {
                                        text: "●"; width: 16px;
                                        color: node.selected ? #cce8ff : #888;
                                        font-size: 8px;
                                        horizontal-alignment: center; vertical-alignment: center;
                                    }

                                    // Title
                                    Text {
                                        text: node.title;
                                        color: node.selected ? white : #1a1a1a;
                                        font-size: 13px; vertical-alignment: center;
                                        overflow: elide; horizontal-stretch: 1;
                                    }

                                    // Bookmark count badge (folders only)
                                    if node.kind == 0 && node.count > 0: Rectangle {
                                        width: max(18px, node.count > 9 ? 22px : 18px); height: 14px;
                                        background: node.selected ? #ffffff30 : #0078d420; border-radius: 7px;
                                        Text { text: node.count > 99 ? "99+" : node.count; color: node.selected ? white : #0078d4; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }
                        }
                    }
                }

                // Splitter
                Rectangle {
                    width: 4px; background: #e0e0e0;
                    TouchArea {
                        mouse-cursor: col-resize;
                        moved => {
                            root.tree-width-px = max(100, min(500, root.tree-width-px + round(self.mouse-x / 1px)));
                            root.tree-width-changed(root.tree-width-px);
                        }
                    }
                }

                // Right: LIST mode or DETAIL mode
                VerticalBox {
                    padding: 0px; spacing: 0px; horizontal-stretch: 1;

                    // ── LIST mode: subfolders + bookmarks ─────────────────
                    if root.active-bookmark == 0: VerticalBox {
                        padding: 0px; spacing: 0px;

                        // Breadcrumb
                        if root.breadcrumb != "": Rectangle {
                            height: 20px; background: #fffce8; border-color: #e8e0a0; border-width: 1px;
                            HorizontalBox {
                                padding-left: 8px;
                                Text { text: root.breadcrumb; font-size: 11px; color: #666; vertical-alignment: center; }
                            }
                        }

                        Rectangle {
                            height: 22px; background: #f0f0f0; border-color: #ddd; border-width: 1px;
                            HorizontalBox {
                                padding-left: 6px; spacing: 0px;
                                Text { text: "Название"; font-size: 11px; color: #555; width: 250px; vertical-alignment: center; }
                                Text { text: "URL / Описание"; font-size: 11px; color: #555; horizontal-stretch: 1; vertical-alignment: center; }
                                Rectangle { width: 4px; }
                                Button { text: root.sort-label; clicked => { root.sort-toggle(); } }
                                Rectangle { width: 4px; }
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            VerticalBox {
                                padding: 2px; spacing: 0px; alignment: start;

                                // Right items: folders first, then bookmarks
                                for item in root.right-items: Rectangle {
                                    height: 22px;
                                    background: item.selected ? #0078d4 : transparent;
                                    border-radius: 2px;

                                    TouchArea {
                                        clicked => {
                                            if item.kind == 0 { root.right-folder-clicked(item.id); }
                                            else { root.right-bookmark-clicked(item.id); }
                                        }
                                        double-clicked => {
                                            if item.kind == 0 { root.right-folder-clicked(item.id); }
                                            else { root.bookmark-open(item.url); }
                                        }
                                        pointer-event(e) => {
                                            if e.button == PointerEventButton.right && e.kind == PointerEventKind.down {
                                                if item.kind == 0 { root.folder-right-click(item.id); }
                                                else { root.bookmark-right-click(item.id); }
                                            }
                                        }
                                    }

                                    HorizontalBox {
                                        padding-left: 4px; padding-right: 4px; padding-top: 2px; padding-bottom: 2px; spacing: 3px;

                                        // Icon: folder or favicon/dot
                                        Rectangle {
                                            width: 16px;
                                            if item.kind == 0: Image {
                                                source: Icons.folder-closed;
                                                width: 16px; height: 16px; image-rendering: pixelated;
                                            }
                                            if item.kind == 1 && item.has-favicon: Image {
                                                source: item.favicon; width: 16px; height: 16px; image-rendering: pixelated;
                                            }
                                            if item.kind == 1 && !item.has-favicon: Text {
                                                text: "●"; color: item.selected ? #aaccff : #aaa;
                                                font-size: 8px; horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }

                                        Text {
                                            text: item.title;
                                            color: item.selected ? white : #1a1a1a;
                                            font-size: 13px; vertical-alignment: center; width: 234px; overflow: elide;
                                        }
                                        Text {
                                            text: item.kind == 0 ? ("Папка") : item.url;
                                            color: item.kind == 0 ? (item.selected ? #cce0ff : #666) : (item.selected ? #bbddff : #0055cc);
                                            font-size: 12px; vertical-alignment: center; overflow: elide; horizontal-stretch: 1;
                                        }

                                        // Folder count badge
                                        if item.kind == 0 && item.count > 0: Rectangle {
                                            width: max(18px, item.count > 9 ? 22px : 18px); height: 14px;
                                            background: item.selected ? #ffffff30 : #0078d420; border-radius: 7px;
                                            Text { text: item.count; color: item.selected ? white : #0078d4; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                        if item.kind == 1 && item.check-status != "": Rectangle {
                                            width: 30px; border-radius: 3px;
                                            background: item.check-status == "OK" ? #22aa44 : #cc2200;
                                            Text { text: item.check-status; color: white; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ── DETAIL mode: bookmark card ─────────────────────────
                    if root.active-bookmark != 0: VerticalBox {
                        padding: 0px; spacing: 0px;

                        // Back button header
                        Rectangle {
                            height: 26px; background: #f0f0f0; border-color: #ddd; border-width: 1px;
                            HorizontalBox {
                                padding: 4px; spacing: 8px; alignment: start;
                                Button { text: "← Назад"; clicked => { root.back-to-list(); } }
                                Text { text: "Свойства ссылки"; font-size: 12px; color: #555; vertical-alignment: center; }
                            }
                        }

                        // Detail card body
                        ScrollView {
                            vertical-stretch: 1;
                            Rectangle {
                                background: white;
                                VerticalBox {
                                    padding: 20px; spacing: 14px; alignment: start;

                                    // Favicon + Title row
                                    HorizontalBox {
                                        spacing: 12px; alignment: start;

                                        // Favicon (32x32 or dot)
                                        Rectangle {
                                            width: 32px; height: 32px;
                                            if root.detail-has-favicon: Image {
                                                source: root.detail-favicon;
                                                width: 32px; height: 32px;
                                                image-rendering: pixelated;
                                            }
                                            if !root.detail-has-favicon: Rectangle {
                                                width: 32px; height: 32px;
                                                background: #f0f0f0; border-radius: 4px;
                                                border-color: #ddd; border-width: 1px;
                                                Text { text: "●"; font-size: 16px; color: #aaa; horizontal-alignment: center; vertical-alignment: center; }
                                            }
                                        }

                                        // Title
                                        Text {
                                            text: root.detail-title;
                                            font-size: 16px; font-weight: 700;
                                            color: #111;
                                            wrap: word-wrap;
                                            vertical-alignment: center;
                                        }
                                    }

                                    // URL
                                    Rectangle {
                                        background: #f0f4ff; border-radius: 4px;
                                        border-color: #c0d0f0; border-width: 1px;
                                        height: 36px;
                                        HorizontalBox {
                                            padding: 8px; spacing: 8px;
                                            Text {
                                                text: root.detail-url;
                                                font-size: 13px; color: #0044cc;
                                                vertical-alignment: center;
                                                overflow: elide;
                                                horizontal-stretch: 1;
                                            }
                                            Button {
                                                text: "Открыть";
                                                primary: true;
                                                clicked => { root.bookmark-open(root.detail-url); }
                                            }
                                        }
                                    }

                                    // Note (if any)
                                    if root.detail-note != "": Rectangle {
                                        background: #fffce8; border-radius: 4px;
                                        border-color: #e8e0a0; border-width: 1px;
                                        VerticalBox {
                                            padding: 8px;
                                            Text { text: "Заметка:"; font-size: 11px; color: #888; }
                                            Text { text: root.detail-note; font-size: 13px; color: #333; wrap: word-wrap; }
                                        }
                                    }

                                    // Action buttons
                                    HorizontalBox {
                                        spacing: 8px; alignment: start;
                                        Button { text: "Редактировать [F4]"; clicked => { root.edit-requested(); } }
                                        Button { text: "Переименовать [F2]"; clicked => { root.rename-requested(); } }
                                        Button { text: "Удалить [Del]";      clicked => { root.delete-selected(); } }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Status bar
            Rectangle {
                height: 20px; background: #f0f0f0; border-color: #ddd; border-width: 1px;
                HorizontalBox {
                    padding-left: 8px;
                    Text { text: root.status-text; font-size: 11px; color: #555; vertical-alignment: center; }
                }
            }
        }
    }

    // ══ Dropdown menus ════════════════════════════════════════════════════════
    if root.active-menu != "": TouchArea { clicked => { root.active-menu = ""; } }

    if root.active-menu == "file": Rectangle {
        x: 2px; y: 46px; width: 210px; background: white; border-color: #aaa; border-width: 1px; drop-shadow-blur: 6px; drop-shadow-color: #20000000;
        VerticalBox { padding: 2px; spacing: 0px;
            MenuItem { text: "Новая база данных...";    clicked => { root.active-menu=""; root.new-db(); } }
            MenuItem { text: "Открыть базу данных...";  clicked => { root.active-menu=""; root.open-db(); } }
            MenuItem { separator: true; }
            MenuItem { text: "Резервная копия...";      clicked => { root.active-menu=""; root.backup-db(); } }
        }
        height: 5 * 22px + 2 * 5px + 4px;
    }

    if root.active-menu == "links": Rectangle {
        x: 56px; y: 46px; width: 230px; background: white; border-color: #aaa; border-width: 1px; drop-shadow-blur: 6px; drop-shadow-color: #20000000;
        VerticalBox { padding: 2px; spacing: 0px;
            MenuItem { text: "+ Новая ссылка  Ctrl+N";  clicked => { root.active-menu=""; root.show-bookmark-dlg = true; } }
            MenuItem { text: "+ Новая папка";            clicked => { root.active-menu=""; root.show-folder-dlg = true; } }
            MenuItem { separator: true; }
            MenuItem { text: "Свойства       F4";        clicked => { root.active-menu=""; root.edit-requested(); } }
            MenuItem { text: "Переименовать  F2";        clicked => { root.active-menu=""; root.rename-requested(); } }
            MenuItem { text: "Удалить        Del";       clicked => { root.active-menu=""; root.delete-selected(); } }
            MenuItem { separator: true; }
            MenuItem { text: "Загрузить favicon'ы";      clicked => { root.active-menu=""; root.load-favicons(); } }
            MenuItem { text: "Проверить ссылки";         clicked => { root.active-menu=""; root.check-links(); } }
            MenuItem { text: "Поиск дублей";             clicked => { root.active-menu=""; root.find-duplicates(); } }
            MenuItem { text: "Все ссылки";               clicked => { root.active-menu=""; root.show-all(); } }
        }
        height: 11 * 22px + 2 * 5px + 4px;
    }

    if root.active-menu == "transfer": Rectangle {
        x: 112px; y: 46px; width: 230px; background: white; border-color: #aaa; border-width: 1px; drop-shadow-blur: 6px; drop-shadow-color: #20000000;
        VerticalBox { padding: 2px; spacing: 0px;
            MenuItem { text: "Экспорт в HTML...";     clicked => { root.active-menu=""; root.export-html(); } }
            MenuItem { text: "Экспорт в TXT...";      clicked => { root.active-menu=""; root.export-txt(); } }
            MenuItem { separator: true; }
            MenuItem { text: "Импорт из ua.dat...";   clicked => { root.active-menu=""; root.import-uadat(); } }
            MenuItem { text: "Импорт из HTML...";     clicked => { root.active-menu=""; root.import-html(); } }
            MenuItem { text: "Импорт из браузера..."; clicked => { root.active-menu=""; root.import-browser(); } }
        }
        height: 7 * 22px + 1 * 5px + 4px;
    }

    if root.active-menu == "search": Rectangle {
        x: 176px; y: 46px; width: 200px; background: white; border-color: #aaa; border-width: 1px; drop-shadow-blur: 6px; drop-shadow-color: #20000000;
        VerticalBox { padding: 2px; spacing: 0px;
            MenuItem { text: "Найти...  Ctrl+F"; clicked => { root.active-menu=""; search-input.focus(); } }
            MenuItem { separator: true; }
            MenuItem { text: "Поиск дублей";     clicked => { root.active-menu=""; root.find-duplicates(); } }
            MenuItem { text: "Все ссылки";       clicked => { root.active-menu=""; root.show-all(); } }
        }
        height: 4 * 22px + 1 * 5px + 4px;
    }

    if root.active-menu == "view": Rectangle {
        x: 232px; y: 46px; width: 210px; background: white; border-color: #aaa; border-width: 1px; drop-shadow-blur: 6px; drop-shadow-color: #20000000;
        VerticalBox { padding: 2px; spacing: 0px;
            MenuItem { text: "Развернуть все папки";  clicked => { root.active-menu=""; root.expand-all(); } }
            MenuItem { text: "Свернуть все папки";    clicked => { root.active-menu=""; root.collapse-all(); } }
            MenuItem { separator: true; }
            MenuItem { text: "Все ссылки"; clicked => { root.active-menu=""; root.show-all(); } }
        }
        height: 3 * 22px + 1 * 5px + 4px;
    }

    // ══ Context menu ══════════════════════════════════════════════════════════
    if root.show-ctx: Rectangle {
        background: transparent;
        TouchArea { clicked => { root.show-ctx = false; } }
        Rectangle {
            x: root.ctx-is-folder ? 244px : 450px; y: 92px;
            width: 210px; background: white; border-color: #aaa; border-width: 1px; drop-shadow-blur: 8px; drop-shadow-color: #30000000;
            VerticalBox { padding: 2px; spacing: 0px;
                if root.ctx-is-folder: MenuItem { text: "Открыть";          clicked => { root.show-ctx=false; root.tree-folder-clicked(root.ctx-id); } }
                if root.ctx-is-folder: MenuItem { text: "+ Подпапка";       clicked => { root.show-ctx=false; root.ctx-new-sub(root.ctx-id); } }
                if root.ctx-is-folder: MenuItem { text: "+ Ссылка в папку"; clicked => { root.show-ctx=false; root.ctx-new-bm-in(root.ctx-id); } }
                if root.ctx-is-folder: MenuItem { separator: true; }
                if root.ctx-is-folder: MenuItem { text: "Экспорт папки";    clicked => { root.show-ctx=false; root.ctx-export-folder(root.ctx-id); } }
                if root.ctx-is-folder: MenuItem { text: "Загрузить favicon"; clicked => { root.show-ctx=false; root.ctx-load-favicons-folder(root.ctx-id); } }
                if root.ctx-is-folder: MenuItem { separator: true; }
                if !root.ctx-is-folder: MenuItem { text: "Открыть URL";     clicked => { root.show-ctx=false; root.ctx-open(root.ctx-id); } }
                if !root.ctx-is-folder: MenuItem { text: "Свойства  F4";    clicked => { root.show-ctx=false; root.ctx-edit(root.ctx-id); } }
                if !root.ctx-is-folder: MenuItem { text: "Копировать URL";  clicked => { root.show-ctx=false; root.ctx-copy-url(root.ctx-id); } }
                if !root.ctx-is-folder: MenuItem { text: "Переместить в..."; clicked => { root.show-ctx=false; root.ctx-move(root.ctx-id); } }
                if !root.ctx-is-folder: MenuItem { separator: true; }
                MenuItem { text: "Переименовать  F2"; clicked => { root.show-ctx=false; root.ctx-rename(root.ctx-id); } }
                MenuItem { text: "Удалить";           clicked => { root.show-ctx=false; root.ctx-delete(root.ctx-id); } }
            }
        }
    }

    // ══ Dialogs ═══════════════════════════════════════════════════════════════

    if root.show-folder-dlg: Rectangle {
        background: #88000000; TouchArea { clicked => { root.show-folder-dlg = false; } }
        Rectangle { width: 320px; height: 140px; background: white; border-radius: 5px; border-color: #aaa; border-width: 1px; drop-shadow-blur: 10px; drop-shadow-color: #30000000;
            VerticalBox { padding: 16px; spacing: 12px;
                Text { text: "Новая папка"; font-size: 14px; font-weight: 700; }
                fn-in := LineEdit { placeholder-text: "Название папки"; }
                HorizontalBox { spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-folder-dlg = false; } }
                    Button { text: "Создать"; primary: true; clicked => { if fn-in.text != "" { root.new-folder-confirmed(fn-in.text); root.show-folder-dlg = false; } } } } } }
    }

    if root.show-bookmark-dlg: Rectangle {
        background: #88000000; TouchArea { clicked => { root.show-bookmark-dlg = false; } }
        Rectangle { width: 420px; height: 220px; background: white; border-radius: 5px; border-color: #aaa; border-width: 1px; drop-shadow-blur: 10px; drop-shadow-color: #30000000;
            VerticalBox { padding: 16px; spacing: 10px;
                Text { text: "Новая ссылка"; font-size: 14px; font-weight: 700; }
                bm-url  := LineEdit { placeholder-text: "URL (https://...)"; }
                bm-ttl  := LineEdit { placeholder-text: "Название (необязательно)"; }
                bm-note := LineEdit { placeholder-text: "Заметка (необязательно)"; }
                HorizontalBox { spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-bookmark-dlg = false; } }
                    Button { text: "Добавить"; primary: true;
                        clicked => { if bm-url.text != "" { root.new-bookmark-confirmed(bm-ttl.text, bm-url.text, bm-note.text); root.show-bookmark-dlg = false; } } } } } }
    }

    if root.show-edit-dlg: Rectangle {
        background: #88000000; TouchArea { clicked => { root.show-edit-dlg = false; } }
        Rectangle { width: 440px; height: 250px; background: white; border-radius: 5px; border-color: #aaa; border-width: 1px; drop-shadow-blur: 10px; drop-shadow-color: #30000000;
            VerticalBox { padding: 16px; spacing: 10px;
                Text { text: "Свойства ссылки"; font-size: 14px; font-weight: 700; }
                ed-ttl  := LineEdit { text: root.edit-title-val; placeholder-text: "Название"; }
                ed-url  := LineEdit { text: root.edit-url-val;   placeholder-text: "URL"; }
                ed-note := LineEdit { text: root.edit-note-val;  placeholder-text: "Заметка"; }
                HorizontalBox { spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-edit-dlg = false; } }
                    Button { text: "Сохранить"; primary: true; clicked => { root.edit-confirmed(ed-ttl.text, ed-url.text, ed-note.text); root.show-edit-dlg = false; } } } } }
    }

    if root.show-rename-dlg: Rectangle {
        background: #88000000; TouchArea { clicked => { root.show-rename-dlg = false; } }
        Rectangle { width: 340px; height: 140px; background: white; border-radius: 5px; border-color: #aaa; border-width: 1px; drop-shadow-blur: 10px; drop-shadow-color: #30000000;
            VerticalBox { padding: 16px; spacing: 12px;
                Text { text: "Переименовать"; font-size: 14px; font-weight: 700; }
                rn-in := LineEdit { text: root.rename-prefill; placeholder-text: "Новое название"; }
                HorizontalBox { spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-rename-dlg = false; } }
                    Button { text: "ОК"; primary: true; clicked => { if rn-in.text != "" { root.rename-confirmed(rn-in.text); root.show-rename-dlg = false; } } } } } }
    }

    if root.show-move-dlg: Rectangle {
        background: #88000000; TouchArea { clicked => { root.show-move-dlg = false; } }
        Rectangle { width: 300px; height: 380px; background: white; border-radius: 5px; border-color: #aaa; border-width: 1px; drop-shadow-blur: 10px; drop-shadow-color: #30000000;
            VerticalBox { padding: 12px; spacing: 8px;
                Text { text: "Переместить в папку"; font-size: 14px; font-weight: 700; }
                ScrollView { vertical-stretch: 1;
                    VerticalBox { padding: 4px; spacing: 1px; alignment: start;
                        for node in root.tree-nodes: Rectangle {
                            height: node.kind == 0 ? 22px : 0px;
                            background: mi-ta.has-hover ? #0078d4 : transparent; border-radius: 2px;
                            mi-ta := TouchArea {
                                enabled: node.kind == 0;
                                clicked => { if node.kind == 0 { root.ctx-move-confirm(node.id); root.show-move-dlg = false; } }
                            }
                            if node.kind == 0: HorizontalBox {
                                padding-left: node.depth * 12px + 4px; padding-right: 4px; padding-top: 2px; padding-bottom: 2px;
                                Text { text: node.title; font-size: 13px; color: mi-ta.has-hover ? white : #1a1a1a; vertical-alignment: center; overflow: elide; }
                            }
                        }
                    }
                }
                HorizontalBox { alignment: end; Button { text: "Отмена"; clicked => { root.show-move-dlg = false; } } }
            }
        }
    }

    // ── Confirm delete dialog ──────────────────────────────────────────────
    if root.show-confirm-delete: Rectangle {
        background: #88000000;
        Rectangle {
            width: 360px; height: 140px; background: white; border-radius: 5px;
            border-color: #aaa; border-width: 1px; drop-shadow-blur: 10px; drop-shadow-color: #30000000;
            VerticalBox { padding: 16px; spacing: 12px;
                Text { text: "Подтверждение удаления"; font-size: 14px; font-weight: 700; }
                Text { text: root.confirm-delete-text; font-size: 13px; color: #333; wrap: word-wrap; }
                HorizontalBox { spacing: 8px; alignment: end;
                    Button { text: "Отмена"; clicked => { root.show-confirm-delete = false; } }
                    Button { text: "Удалить"; primary: true;
                        clicked => { root.show-confirm-delete = false; root.confirm-delete-yes(); } }
                }
            }
        }
    }

    // ── Favicon progress panel (non-modal, bottom-left) ───────────────────
    if root.show-favicon-progress: Rectangle {
        x: 16px;
        y: root.height - 76px;
        width: 290px; height: 60px;
        background: #f5f5f5;
        border-color: #aaa; border-width: 1px; border-radius: 4px;
        drop-shadow-blur: 8px; drop-shadow-color: #30000000;

        VerticalBox {
            padding: 8px; spacing: 6px;

            HorizontalBox {
                spacing: 8px;
                Text {
                    text: root.favicon-progress-text;
                    font-size: 12px; color: #333;
                    vertical-alignment: center; horizontal-stretch: 1;
                }
                Rectangle {
                    width: 16px; height: 16px; border-radius: 8px;
                    background: #0078d4;
                    Text { text: "×"; color: white; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { clicked => { /* cancel would need callback */ } }
                }
            }

            // Progress bar
            Rectangle {
                height: 6px; background: #e0e0e0; border-radius: 3px;
                Rectangle {
                    x: 0; y: 0; height: 6px; border-radius: 3px;
                    background: #0078d4;
                    width: root.favicon-progress-value * parent.width;
                }
            }
        }
    }
}
