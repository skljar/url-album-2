{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "URL Album",
  "version": "0.1.0",
  "identifier": "com.urlalbum.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "URL Album",
        "width": 1200,
        "height": 750,
        "minWidth": 500,
        "minHeight": 400,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
